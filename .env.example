# ====================================================================
# Copy this file to `.env` and fill in ONE of the following providers.
# Replicate is recommended (cheaper + simpler).
# ====================================================================

# --- Provider 1: Replicate (recommended) ---------------------------
# Sign up at https://replicate.com/  -> Account -> API Tokens
# New users typically get a small free credit allowance.
REPLICATE_API_TOKEN=r8_your_token_here

# --- Provider 2: fal.ai (alternative) ------------------------------
# Sign up at https://fal.ai/dashboard/keys
# fal.ai also gives free credits to new users.
FAL_KEY=
